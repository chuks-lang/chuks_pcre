// Tests for @chuks/pcre — pure-Chuks backtracking regular expressions.
// Run: chuks test tests/index.test.chuks   (and AOT: chuks build … && run)

import { test } from "std/test"
import { Regex, Match } from "../src/index.chuks"

var passed: int = 0
var failed: int = 0
var failures: []string = []
const start = test.now()

// helpers ---------------------------------------------------------------------
function first(pat: string, s: string): string {
    var m: Match? = new Regex(pat).find(s, 0)
    if (m == null) { return "<none>" }
    return m.matched()
}
function grp(pat: string, s: string, g: int): string {
    var m: Match? = new Regex(pat).find(s, 0)
    if (m == null) { return "<none>" }
    return m.group(g)
}
function eq(name: string, got: string, want: string) {
    if (test.assertEqual(got, want, name)) { passed++ } else { failed++; failures.push(name + ": got [" + got + "] want [" + want + "]") }
}
function ok(name: string, cond: bool) {
    if (test.assert(cond, name)) { passed++ } else { failed++; failures.push(name) }
}

// literals, dot, escapes ------------------------------------------------------
eq("literal", first("abc", "xxabcyy"), "abc")
eq("dot", first("a.c", "a-c"), "a-c")
eq("escaped-meta", first("a\\.c", "a.c"), "a.c")
ok("escaped-meta-no", !new Regex("a\\.c").test("axc"))
eq("tab-escape", first("x\\ty", "x\ty"), "x\ty")

// quantifiers -----------------------------------------------------------------
eq("star", first("a*", "aaab"), "aaa")
eq("plus", first("a+", "baaa"), "aaa")
eq("opt", first("ab?c", "ac"), "ac")
eq("lazy-plus", first("a+?", "aaa"), "a")
eq("brace-range", first("a{2,3}", "aaaa"), "aaa")
eq("brace-exact", first("a{2}", "aaaa"), "aa")
eq("brace-open", first("a{2,}", "aaaa"), "aaaa")
eq("greedy-backtrack", first("a.*c", "axcyc"), "axcyc")
eq("lazy-backtrack", first("a.*?c", "axcyc"), "axc")

// classes ---------------------------------------------------------------------
eq("digit", first("\\d+", "abc123def"), "123")
eq("word", first("\\w+", "  hello!"), "hello")
eq("space", first("\\s+", "ab   cd"), "   ")
eq("class-range", first("[a-f]+", "abcXYZ"), "abc")
eq("class-neg", first("[^0-9]+", "abc123"), "abc")
eq("class-mixed", first("[\\d.]+", "v1.2.3z"), "1.2.3")
eq("class-literal-dash", first("[a-]+", "a-a-b"), "a-a-")

// anchors ---------------------------------------------------------------------
eq("caret", first("^abc", "abcdef"), "abc")
ok("caret-no", !new Regex("^abc").test("xabc"))
eq("dollar", first("def$", "abcdef"), "def")
eq("wordb", first("\\bcat\\b", "a cat here"), "cat")
ok("nonwordb", new Regex("\\Bcat").test("scatter"))

// groups & alternation --------------------------------------------------------
eq("group1", grp("(\\w+)@", "ada@chuks", 1), "ada")
eq("alt", first("cat|dog", "a dog"), "dog")
eq("alt-backtrack", first("(ab|a)b", "ab"), "ab")
eq("noncap", first("(?:ab)+", "ababab"), "ababab")
eq("nested-last", grp("((a)(b))+", "abab", 1), "ab")  // repeated group = last iteration

// backreferences --------------------------------------------------------------
ok("backref-yes", new Regex("(\\w)\\1").test("hello"))
ok("backref-no", !new Regex("(\\w)\\1").test("abcd"))
eq("backref-word", grp("(\\w+) \\1", "the the end", 1), "the")

// named groups ----------------------------------------------------------------
function named(pat: string, s: string, n: string): string {
    var m: Match? = new Regex(pat).find(s, 0)
    if (m == null) { return "<none>" }
    return m.groupByName(n)
}
eq("named", named("(?<user>\\w+)@(?<host>\\w+)", "ada@chuks", "host"), "chuks")
ok("named-backref", new Regex("(?<c>\\w)\\k<c>").test("hello"))

// lookahead -------------------------------------------------------------------
eq("lookahead-pos", first("foo(?=bar)", "foobar"), "foo")
ok("lookahead-neg", new Regex("foo(?!bar)").test("foobaz"))
ok("lookahead-neg2", !new Regex("foo(?!bar)").test("foobar"))

// lookbehind ------------------------------------------------------------------
ok("lookbehind-pos", new Regex("(?<=@)\\w+").test("a@host"))
eq("lookbehind-grab", first("(?<=\\$)\\d+", "price $42 ok"), "42")
ok("lookbehind-neg", new Regex("(?<!\\d)abc").test("xabc"))

// \G anchor (TextMate-style) --------------------------------------------------
ok("G-at-start", new Regex("\\G\\d").test("5ab"))
ok("G-not-floating", !new Regex("\\Gb").test("ab"))

// position API ----------------------------------------------------------------
function span(pat: string, s: string, g: int): string {
    var m: Match? = new Regex(pat).find(s, 0)
    if (m == null) { return "<none>" }
    var sp: []int = m.span(g)
    return string(sp[0]) + ":" + string(sp[1])
}
eq("span-whole", span("b.d", "abcde", 0), "1:4")
eq("span-group", span("a(bc)d", "abcd", 1), "1:3")

// findAll ---------------------------------------------------------------------
var all: []Match = new Regex("\\d+").findAll("a1b22c333")
eq("findall-count", string(all.length), "3")
eq("findall-last", all[2].matched(), "333")

// real-world: tokenize a tiny expression --------------------------------------
var toks: []Match = new Regex("\\d+|[+\\-*/]|\\w+").findAll("foo + 42 * bar")
eq("tokenize-count", string(toks.length), "5")
eq("tokenize-2", toks[2].matched(), "42")

test.report(passed, failed, failures, test.now() - start)
